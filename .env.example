# SMTP server hostname used for alert email delivery.
ALERT_SMTP_HOST=smtp.protonmail.ch
# SMTP server port used for alert email delivery.
ALERT_SMTP_PORT=587
# SMTP account username used to authenticate alert email delivery.
ALERT_SMTP_USER=alert@alexbomber.com
# SMTP account password or token used to authenticate alert email delivery.
ALERT_SMTP_PASSWORD=changeme-proton-smtp-token
# Email address used as the alert sender.
ALERT_FROM=alert@alexbomber.com
# Email address that receives alert messages.
ALERT_TO=changeme@example.com
# Web admin username used by the authentication layer.
ADMIN_USERNAME=admin
# Bcrypt hash for the web admin password.
ADMIN_PASSWORD_HASH=changeme-bcrypt-hash
# Absolute filesystem path to the storcli64 executable.
STORCLI_PATH=/usr/local/sbin/storcli64
# Set true on production where storcli64 requires root via sudo. Keep false locally.
STORCLI_USE_SUDO=false
# Number of seconds between background metrics collection runs.
METRICS_INTERVAL_SECONDS=300
# Number of days to keep full-resolution controller, virtual drive, and physical drive snapshots.
METRICS_RAW_RETENTION_DAYS=30
# Number of days to keep hourly physical drive metric rollups before daily downsampling.
METRICS_HOURLY_RETENTION_DAYS=365
# Set true to store the full storcli JSON payload with each controller snapshot for forensics.
STORE_RAW_SNAPSHOT_PAYLOAD=false
# Set false to disable the background collector scheduler.
COLLECTOR_ENABLED=true
# Filesystem lock used to keep only one collector scheduler active across app workers.
COLLECTOR_LOCK_PATH=/tmp/megaraid-dashboard-collector.lock
# Drive temperature in Celsius that raises a warning event.
TEMP_WARNING_CELSIUS=55
# Drive temperature in Celsius that raises a critical event.
TEMP_CRITICAL_CELSIUS=60
# Temperature drop below a threshold required before clearing warning or critical state.
TEMP_HYSTERESIS_CELSIUS=5
# CacheVault capacitance percent below which a warning event is emitted.
CV_CAPACITANCE_WARNING_PERCENT=70
# SQLAlchemy database URL used by the application.
DATABASE_URL=sqlite:///./megaraid.db
# Application logging threshold.
LOG_LEVEL=INFO
