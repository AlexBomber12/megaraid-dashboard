# SMTP server hostname used for alert email delivery.
ALERT_SMTP_HOST=smtp.protonmail.ch
# SMTP server port used for alert email delivery.
ALERT_SMTP_PORT=587
# SMTP account username used to authenticate alert email delivery.
ALERT_SMTP_USER=alert@alexbomber.com
# SMTP account password or token used to authenticate alert email delivery.
ALERT_SMTP_PASSWORD=changeme-proton-smtp-token
# Email address used as the alert sender.
ALERT_FROM=alert@alexbomber.com
# Email address that receives alert messages.
ALERT_TO=changeme@example.com
# Web admin username used by the authentication layer.
ADMIN_USERNAME=admin
# Bcrypt hash for the web admin password.
ADMIN_PASSWORD_HASH=changeme-bcrypt-hash
# Absolute filesystem path to the storcli64 executable.
STORCLI_PATH=/usr/local/sbin/storcli64
# Number of seconds between background metrics collection runs.
METRICS_INTERVAL_SECONDS=300
# SQLAlchemy database URL used by the application.
DATABASE_URL=sqlite:///./megaraid.db
# Application logging threshold.
LOG_LEVEL=INFO
